LLM_PROVIDER=nebius
NEBIUS_API_KEY=your_nebius_api_key
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
LLM_MODEL=Qwen/Qwen3-30B-A3B

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=kids-daily-story-history
PINECONE_DIMENSION=384
PINECONE_AUTO_CREATE_INDEX=false
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional Mem0 long-term child preference memory.
# Uses the same child_id as Pinecone metadata/vector IDs.
MEM0_API_KEY=your_mem0_api_key

# Optional fallback if you set LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gmail SMTP email.
# Keep mock mode true for demos. Set false only after creating a Gmail app password.
STORY_AGENT_MOCK_EMAIL=true
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
STORY_AGENT_FROM_EMAIL=your_email@gmail.com

# Optional generic SMTP override. Gmail uses smtp.gmail.com:587 by default.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional: existing remote MCP server URL for Gmail-style approval checks.
STORY_AGENT_MCP_URL=

# OpenAI image generation for story illustrations.
# If OPENAI_IMAGE_MCP_URL is set, the agent calls that MCP tool.
# Otherwise, it uses the OpenAI Images API directly with OPENAI_API_KEY.
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low

# Optional ElevenLabs audio narration attachment.
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional existing OpenAI Image MCP server.
OPENAI_IMAGE_MCP_URL=http://localhost:3001/mcp
OPENAI_IMAGE_MCP_TRANSPORT=streamable_http
OPENAI_IMAGE_MCP_TOOL_NAME=generate_image
